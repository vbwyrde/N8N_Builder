{
  "scenario": {
    "workflow_id": "file-proc-v1",
    "feedback": "The file processing is working but it's too slow for large files. Need to add batching.",
    "additional_requirements": "Add batch processing for files larger than 10MB"
  },
  "original_workflow": {
    "name": "File Processing Workflow",
    "nodes": [
      {
        "id": "0",
        "name": "Manual Trigger",
        "type": "n8n-nodes-base.manualTrigger",
        "parameters": {},
        "position": [
          40,
          300
        ]
      },
      {
        "id": "1",
        "name": "Watch Folder",
        "type": "n8n-nodes-base.watchFolder",
        "parameters": {
          "folderPath": "/watch/folder",
          "options": {
            "includeSubfolders": false
          }
        },
        "position": [
          240,
          300
        ]
      },
      {
        "id": "2",
        "name": "Read File",
        "type": "n8n-nodes-base.readBinaryFile",
        "parameters": {
          "filePath": "={{$node['Watch Folder'].json['path']}}"
        },
        "position": [
          460,
          300
        ]
      },
      {
        "id": "3",
        "name": "Process Data",
        "type": "n8n-nodes-base.function",
        "parameters": {
          "functionCode": "// Process the file data\nconst data = items[0].binary.data;\nreturn [{json: {processed: true, size: data.length}}];"
        },
        "position": [
          680,
          300
        ]
      },
      {
        "id": "4",
        "name": "Save Results",
        "type": "n8n-nodes-base.writeBinaryFile",
        "parameters": {
          "fileName": "processed_{{$node['Watch Folder'].json['name']}}",
          "dataPropertyName": "data"
        },
        "position": [
          900,
          300
        ]
      }
    ],
    "connections": {
      "Manual Trigger": {
        "main": [
          [
            {
              "node": "Watch Folder",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Watch Folder": {
        "main": [
          [
            {
              "node": "Read File",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Read File": {
        "main": [
          [
            {
              "node": "Process Data",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Process Data": {
        "main": [
          [
            {
              "node": "Save Results",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
